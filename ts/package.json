{
  "name": "@eventconnectors/ndtrc-model",
  "version": "1.2.1",
  "description": "Zod schemas for the NDTRC tourism data model — TypeScript port of the Groovy ndtrc_model library",
  "keywords": [
    "ndtrc",
    "eventconnectors",
    "feed-factory",
    "zod",
    "tourism"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheFeedFactory/ndtrc_model.git",
    "directory": "ts"
  },
  "bugs": {
    "url": "https://github.com/TheFeedFactory/ndtrc_model/issues"
  },
  "homepage": "https://github.com/TheFeedFactory/ndtrc_model/tree/master/ts#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=18"
  }
}
